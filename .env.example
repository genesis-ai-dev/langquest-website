#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY_PREVIEW=""
DOTENV_PUBLIC_KEY_PRODUCTION=""

# Copy to .env.preview / .env.production, fill values, then:
#   pnpm encrypt:preview
#   pnpm encrypt:production
#
# Local overrides (gitignored): .env.local
# Private keys (gitignored): .env.keys — back up with dotenvx-ops backup

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_BUCKET="local"
SUPABASE_SERVICE_ROLE_KEY=""

NEXT_PUBLIC_SITE_URL=""
NEXT_PUBLIC_APP_SCHEME="langquest-dev"
NEXT_PUBLIC_ENVIRONMENT="preview"

# App identity
TEAM_ID="apple_team_id_10_chars"
APP_IDS="com.etengenesis.langquest.development"
ANDROID_SHA256_FINGERPRINTS=""

# Resend
RESEND_API_KEY=""
AUDIENCE_ID=""

# Audio concatenation worker
AUDIO_CONCAT_WORKER_URL=""
AUDIO_CONCAT_WORKER_TOKEN=""
