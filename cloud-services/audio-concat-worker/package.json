{
  "name": "audio-concat-worker",
  "version": "1.0.0",
  "description": "Cloudflare Worker for concatenating audio segments",
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc --noEmit",
    "dev": "wrangler --config wrangler.toml dev",
    "deploy": "wrangler --config wrangler.toml deploy",
    "versions:upload": "wrangler --config wrangler.toml versions upload"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.78.0"
  }
}
